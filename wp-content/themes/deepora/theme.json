	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background-primary)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"css": "\n/* =========== Paragraphs Section =========== */\n\n.p-max-14 {\n  max-width: 14em;\n  }\n  .p-max-11 {\n  max-width: 11em;\n  }\n  .p-max-8{\n  max-width: 8em;\n  }\n  \n  .p-max-30{\n  max-width: 30em;\n  margin: auto;\n  }\n  \n  \n  \n  .p-theme-style{\n   opacity: .7;\n  \n   }\n  \n  /* =========== Mobile Menu =========== */\n  @media only screen and (max-width: 769px){\n      .wp-block-navigation__responsive-container{\n      height: 100vh;\n          z-index: 99;\n          \n      }\n      .heading-logo{\n      font-size: 1rem;\n      }\n      .menu-content-wrapper{\n      display: flex;\n      justify-content: space-between;\n      width: 100%;\n    flex-direction: row;\n      flex-wrap: nowrap;\n      gap: 40px;\n      \n      }\n      \n      \n  }\n  @media only screen and (max-width: 1025px){\n  .top-navigation-cta-wrapper{\n      display: none!important;\n      }}\n  /* =========== Hero Section =========== */\n  .hero-section{\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  place-content: center;\n  width: 100%;\n  \n  }\n  \n  .hero-section-wrapper{\n  position: relative;\n  z-index: 5;\n  }\n  \n  .top-navigation-bar{\n  position: absolute;\n  top:0;\n  left: 0;\n  width:100%;\n  z-index: 10;\n  backdrop-filter: blur(10px);\n  z-index:99;\n  transition: all 0.3s ease;\n\n\n  }\n  \n  .top-navigation-bar.fixed {\n    position: fixed;\n  \n  }\n\n  .hero-bottom-content-wrapper{\n  position: relative;\n  z-index: 5;\n  }\n  .hero-video-wrapper{\n  position: relative;\n  z-index: 5;\n  }\n \n  \n  .wp-block-list{\n  padding-left: 0!important;\n  \n  }\n  .line-bg-linear{\n  background: var(--wp--preset--color--text-secondary);\n  color:  var(--wp--preset--color--text-primary);\n  height: 1px!important;\n  width: 100%;\n  }\n  \n  .team-member-card{\n  min-width: 360px;\n  }\n  \n  /* =========== Sticky Effect =========== */\n  .sticky-cover{\n    max-width: 100%;\n    width: 100%;\n    height: 100vh;\n    img{\n      object-fit: cover;\n    }\n  }\n  .checkmark-box{\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 25px;\n  height: 25px;\n  border-radius: 50%;\n  font-size: 14px;\n  text-align:center;\n  }\n  \n  .icon-box{\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 50px;\n  height: 50px;\n  border-radius: 50%;\n  text-align: center;\n  }\n",
		"elements": {
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)"
				}
			},
